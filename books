from datetime import datetime

books = {
    "Python": {"issued": False},
    "Java": {"issued": False},
    "C++": {"issued": False}
}

issued_books = {}

def view_books():
    for book, info in books.items():
        status = "Available" if not info["issued"] else "Issued"
        print(f"{book} - {status}")

def issue_book(book, student):
    if book in books and not books[book]["issued"]:
        books[book]["issued"] = True
        issued_books[book] = {
            "student": student,
            "date": datetime.now()
        }
        print("Book issued successfully")
    else:
        print("Book not available")

def return_book(book):
    if book in issued_books:
        issue_date = issued_books[book]["date"]
        return issue_date
    else:
        print("Book was not issued")
        return None

def complete_return(book):
    books[book]["issued"] = False
    del issued_books[book]
    
from datetime import datetime

def calculate_fine(issue_date):
    days = (datetime.now() - issue_date).days

    if days <= 7:
        return 0
    else:
        weeks = (days - 7) // 7 + 1
        return weeks * 10    
        
while True:
    print("\n----- Library Menu -----")
    print("1. View Books")
    print("2. Issue Book")
    print("3. Return Book")
    print("4. Exit")

    choice = input("Enter choice: ")

    if choice == "1":
        view_books()

    elif choice == "2":
        book = input("Enter book name: ")
        student = input("Enter student name: ")
        issue_book(book, student)

    elif choice == "3":
        book = input("Enter book name: ")
        issue_date = return_book(book)

        if issue_date:
            fine = calculate_fine(issue_date)
            print("Fine: ₹", fine)
            complete_return(book)

    elif choice == "4":
        print("Thank you!")
        break

    else:
        print("Invalid choice")        
